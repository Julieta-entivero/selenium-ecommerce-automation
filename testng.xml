<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="E-Commerce Test Suite" parallel="classes" thread-count="2">

    <test name="Login Tests">
        <classes>
            <class name="com.shopzone.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Products Tests">
        <classes>
            <class name="com.shopzone.tests.ProductsTest"/>
        </classes>
    </test>

    <test name="Cart Tests">
        <classes>
            <class name="com.shopzone.tests.CartTest"/>
        </classes>
    </test>

    <test name="Checkout Tests">
        <classes>
            <class name="com.shopzone.tests.CheckoutTest"/>
        </classes>
    </test>

</suite>
